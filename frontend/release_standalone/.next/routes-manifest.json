      "regex": "^/admin/bookings/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/bookings/(?<nxtPid>[^/]+?)(?:/)?$"
    },
