# Disable directory listing globally
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block direct access to /admin root - redirect to dashboard
    RewriteRule ^admin/?$ /admin/dashboard/ [R=302,L]

    # If request is a directory without trailing slash, add trailing slash
    # (keeps query string: /auth/callback?code=... → /auth/callback/?code=...)
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.+[^/])$ $1/ [R=301,L]

    # Serve directory index.html when path maps to a folder
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_FILENAME}/index.html -f
    RewriteRule ^(.+)/$ $1/index.html [L]

    # Villa detail: missing slug folders fall through to placeholder
    RewriteCond %{REQUEST_URI} ^/villas/([^/]+)/?$
    RewriteCond %{DOCUMENT_ROOT}/villas/%1 !-d
    RewriteCond %1 !^placeholder$
    RewriteRule ^villas/([^/]+)/?$ /villas/placeholder/index.html [L]

    # Existing files/dirs: serve as-is
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # If /path/index.html exists (export with trailingSlash), serve it
    RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
    RewriteRule ^(.*)$ /$1/index.html [L]

    # Final fallback
    RewriteRule ^(.*)$ /404.html [L]
</IfModule>
