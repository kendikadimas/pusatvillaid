<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Villa detail pages are fully pre-rendered as static HTML (one file per slug).
    # Trailing slash: /villas/some-slug/ serves /villas/some-slug/index.html directly.
    # No placeholder redirect needed - all slugs have their own folder.

    # SPA fallback - serve 404.html for missing routes
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ /404.html [L]
</IfModule>
