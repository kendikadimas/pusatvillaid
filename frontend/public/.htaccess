# Disable directory listing globally
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block direct access to /admin root (no index.html there) - redirect to dashboard
    RewriteRule ^admin/?$ /admin/dashboard/index.html [L]

    # Villa detail pages: serve pre-built static HTML if the slug folder exists.
    # For new villas not yet in the static build, fall through to placeholder.
    # The placeholder page reads the real slug from window.location and fetches from API.
    RewriteCond %{REQUEST_URI} ^/villas/([^/]+)/?$
    RewriteCond %{DOCUMENT_ROOT}/villas/%1 !-d
    RewriteCond %1 !^placeholder$
    RewriteRule ^villas/([^/]+)/?$ /villas/placeholder/index.html [L]

    # SPA fallback - serve 404.html for missing routes
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ /404.html [L]
</IfModule>
